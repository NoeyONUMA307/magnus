# At least one provider key is required (or use Ollama for local-only)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Backend port (default: 3001)
# PORT=3001

# CORS allowed origins (default: http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# Base URL for GitHub PR comment links (default: http://localhost:5173)
# MAGNUS_URL=http://localhost:5173

# Frontend API base URL — only needed if backend is on a different origin
# VITE_API_URL=

# Custom Chromium path for Puppeteer (auto-detected in Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
